# Pre-submission environment configuration
# Copy this to .env and update values for your submission

# Required: API endpoint for the environment server
API_BASE_URL=http://localhost:8000

# Required: Model identifier for inference
MODEL_NAME=gpt-4-turbo

# Required: Hugging Face API token
HF_TOKEN=your_hf_token_here

# Optional: Azure OpenAI settings
AZURE_API_KEY=
AZURE_ENDPOINT=

# Optional: OpenAI API key (if not using Azure)
OPENAI_API_KEY=sk-your-key-here
